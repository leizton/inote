{
  "editor.tokenColorCustomizations": {
    "comments": "#777"
  },
  "editor.fontFamily": "VictorMono-semibold",
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.renderLineHighlight": "gutter",
  "editor.renderControlCharacters": true,
  "editor.minimap.enabled": false,
  "editor.roundedSelection": true,
  "editor.mouseWheelScrollSensitivity": 2.0,
  "editor.foldingStrategy": "auto",
  "editor.tabCompletion": "off",
  "C_Cpp.enhancedColorization": "Enabled",
  "C_Cpp.autocomplete": "Default",
  "[cpp]": {
    "editor.quickSuggestions": true
  },
  "C_Cpp.intelliSenseEngine": "Tag Parser",
  // "editor.rulers": [85],
  "files.autoSave": "afterDelay",
  "workbench.editor.enablePreview": false,
  "workbench.colorCustomizations": {
    "badge.background": "#e04949e0",
    "editor.selectionBackground": "#5eadddd7", // selection
    "editor.selectionForeground": "#ffffff",
    "editor.selectionHighlightBackground": "#ebc177d0", // click match
    "editor.findMatchHighlightBackground": "#e04949e0", // find match
    "editor.findMatchBackground": "#e04949e0"
    /*
    "widget.shadow": "#282c34",
    "scrollbar.shadow": "#282c34",
    "editor.background": "#282c34",
    "editor.foreground": "#d3d3d3",
    "statusBar.foreground": "#fff",
    "statusBar.background": "#282c34",
    "sideBar.background": "#282c34",
    "sideBarSectionHeader.background": "#282c34",
    "sideBarSectionHeader.border": "#282c34",
    "titleBar.activeBackground": "#282c34",
    "titleBar.inactiveBackground": "#282c34",
    "list.activeSelectionBackground": "#282c34",
    "list.inactiveSelectionBackground": "#282c34",
    "list.activeSelectionForeground": "#e04949e0",
    "list.inactiveSelectionForeground": "#e04949e0",
    //*/
    /*
    "widget.shadow": "#fafafa",
    "scrollbar.shadow": "#fafafa",
    "editor.background": "#fafafa",
    "editor.foreground": "#222",
    "editorLineNumber.foreground": "#aaa",
    "statusBar.foreground": "#333",
    "statusBar.background": "#fafafa",
    "sideBar.background": "#fafafa",
    "sideBarSectionHeader.background": "#fafafa",
    "sideBarSectionHeader.border": "#fafafa",
    "titleBar.activeBackground": "#fafafa",
    "titleBar.inactiveBackground": "#fafafa",
    "list.activeSelectionBackground": "#fafafa",
    "list.inactiveSelectionBackground": "#fafafa",
    "list.activeSelectionForeground": "#e04949e0",
    "list.inactiveSelectionForeground": "#e04949e0",
    //*/
  },
  "workbench.startupEditor": "newUntitledFile",
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.decorations.enabled": false,
  "extensions.ignoreRecommendations": false,
  "C_Cpp.errorSquiggles": "Disabled",
  "typescript.check.npmIsInstalled": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.codeLens.recentChange.enabled": false,
  "gitlens.codeLens.authors.enabled": false,
  "terminal.integrated.shellArgs.osx": [
    "-l"
  ],
  "gitlens.advanced.messages": {
    "suppressShowKeyBindingsNotice": false
  },
  "editor.minimap.renderCharacters": true,
  "workbench.enableExperiments": false,
  "workbench.activityBar.visible": false,
  "workbench.list.horizontalScrolling": true,
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "workbench.editor.showTabs": false,
  "workbench.sideBar.location": "left",
  "C_Cpp.updateChannel": "Insiders",
  "http.proxySupport": "off",
  "editor.dragAndDrop": false,
  "terminal.integrated.rendererType": "canvas",
  "editor.renderWhitespace": "none",
  "workbench.statusBar.visible": true,
  "gitlens.advanced.caching.enabled": false,
  "gitlens.blame.highlight.enabled": false,
  "gitlens.currentLine.enabled": false,
  "breadcrumbs.enabled": true,
  "window.title": "${rootName}",
  "gitlens.statusBar.alignment": "left",
  "gitlens.defaultDateStyle": "absolute",
  "gitlens.statusBar.dateFormat": "YYYY-MM-DD",
  "gitlens.blame.format": "${date}  ${author|8}",
  "gitlens.blame.dateFormat": "YYYY-MM-DD",
  "terminal.integrated.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "workbench.editor.limit.value": 10000,
  "editor.cursorSmoothCaretAnimation": true,
  "workbench.editor.tabCloseButton": "off",
  "debug.console.wordWrap": false,
  "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, UseTab: Never, IndentWidth: 2, TabWidth: 2, ColumnLimit: 0, NamespaceIndentation: None, PointerAlignment: Left, AllowShortIfStatementsOnASingleLine: true, AllowShortCaseLabelsOnASingleLine: true, BreakConstructorInitializersBeforeComma: true }",
  "C_Cpp.intelliSenseEngineFallback": "Enabled",
  "C_Cpp.loggingLevel": "Information",
  "C_Cpp.intelliSenseCacheSize": 20480,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.showExitAlert": false,
  "editor.detectIndentation": false,
  "editor.smoothScrolling": true,
  "editor.wordWrapColumn": 500,
  "markdown.preview.lineHeight": 0.88,
  "C_Cpp.experimentalFeatures": "Enabled",
  "search.useIgnoreFiles": false,
  "debug.console.fontFamily": "Ubuntu Mono",
  "terminal.integrated.fontFamily": "VictorMono-semibold",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.shell.osx": "/bin/bash",
  "editor.wordWrap": "wordWrapColumn",
  "[jsonc]": {
    "editor.quickSuggestions": {
      "strings": true
    },
    "editor.suggest.insertMode": "replace"
  },
  "debug.console.fontSize": 13,
  "editor.cursorBlinking": "solid",
  "files.exclude": {
    "/Library/*": true
  },
  "C_Cpp.default.includePath": [
    "/usr/local/Cellar/gcc/10.2.0/include/c++/10.2.0"
  ],
  "C_Cpp.default.forcedInclude": [
    "${workspaceFolder}/**"
  ],
  "C_Cpp.intelliSenseUpdateDelay": 500,
  "editor.fontSize": 14,
  "workbench.colorTheme": "Default Light+",
  "emmet.showSuggestionsAsSnippets": true,
  "files.associations": {
    "BUILD": "python"
  }
}